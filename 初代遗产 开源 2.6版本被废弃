local function PlayEmote(name, id)
	local player = game:GetService("Players").LocalPlayer
	if not player.Character then
		WindUI:Notify({ Title = "错误", Content = "角色不存在", Duration = 2 })
		return
	end

	local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		WindUI:Notify({ Title = "错误", Content = "找不到Humanoid", Duration = 2 })
		return
	end

	if humanoid.RigType ~= Enum.HumanoidRigType.R15 then
		WindUI:Notify({ Title = "错误", Content = "只支持R15角色", Duration = 2 })
		return
	end

	local success, err = pcall(function()
		humanoid:PlayEmoteAndGetAnimTrackById(id)
	end)

	if success then
		WindUI:Notify({ Title = "动作", Content = "正在播放: " .. name, Duration = 2 })
	else
		local desc = humanoid:FindFirstChildOfClass("HumanoidDescription")
		if not desc then
			desc = Instance.new("HumanoidDescription")
			desc.Parent = humanoid
		end
		desc:AddEmote(name, id)
		humanoid:PlayEmoteAndGetAnimTrackById(id)
		WindUI:Notify({ Title = "动作", Content = "正在播放: " .. name, Duration = 2 })
	end
end

