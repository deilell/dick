task.spawn(function()
	local AITab = Window:Tab({
		Title = "AI聊天",
		Icon = "message-square",
		Locked = false,
	})

	AITab:Section({
		Title = "AI智能回复",
		TextXAlignment = "Left",
		TextSize = 17,
	})

	local aiEnabled = false
	local aiRespondToSelf = false
	local aiDebugMode = false
	local aiReplyDelay = 1.5
	local aiMessageHistory = {}
	local aiCooldownPlayers = {}
	local aiChatConnection = nil

	local POLLINATIONS_API_URL = "https://text.pollinations.ai/"

	AITab:Paragraph({
		Title = "功能说明",
		Desc = "AI会自动回复玩家消息\n使用Pollinations AI模型，每次请求独立\n请求很慢不推荐使用",
	})

	AITab:Toggle({
		Title = "启用AI回复",
		Desc = "开启后AI将自动回复所有聊天消息",
		Type = "Checkbox",
		Default = false,
		Callback = function(state)
			aiEnabled = state
			setupAIChatListener()
		end,
	})

	AITab:Toggle({
		Title = "回复自己",
		Desc = "是否回复自己发送的消息",
		Type = "Checkbox",
		Default = false,
		Callback = function(state)
			aiRespondToSelf = state
		end,
	})

	AITab:Toggle({
		Title = "调试模式",
		Desc = "显示AI请求状态",
		Type = "Checkbox",
		Default = false,
		Callback = function(state)
			aiDebugMode = state
		end,
	})

	AITab:Slider({
		Title = "回复延迟",
		Desc = "收到消息后等待几秒再回复",
		Step = 0.1,
		Value = {
			Min = 0,
			Max = 5,
			Default = 1.5,
		},
		Callback = function(value)
			aiReplyDelay = value
		end,
	})

	AITab:Button({
		Title = "清空历史记录",
		Desc = "清除AI回复历史缓存",
		Callback = function()
			aiMessageHistory = {}
			aiCooldownPlayers = {}
			WindUI:Notify({ Title = "AI聊天", Content = "已清空历史记录", Duration = 2 })
		end,
	})

	local function sendAIResponse(playerName, question)
		if not aiEnabled then
			return
		end

		local randomCache = math.random(100000, 999999)

		local prompt = "请用简短的一句话回答：" .. question

		if aiDebugMode then
			WindUI:Notify({
				Title = "API请求",
				Content = string.format(
					"随机ID: %d | 提问: %s",
					randomCache,
					question:sub(1, 20) .. (question:len() > 20 and "..." or "")
				),
				Duration = 2,
			})
		end

		local apiUrl = POLLINATIONS_API_URL .. HttpService:UrlEncode(prompt) .. "?cache=" .. randomCache

		local success, response = pcall(function()
			return request({
				Url = apiUrl,
				Method = "GET",
				Headers = {
					["User-Agent"] = "Roblox/WScript",
				},
			})
		end)

		if not success or not response then
			if aiDebugMode then
				WindUI:Notify({ Title = "API错误", Content = "请求失败", Duration = 2 })
			end
			return
		end

		if response.StatusCode ~= 200 then
			if aiDebugMode then
				WindUI:Notify({
					Title = "API错误",
					Content = "状态码: " .. response.StatusCode,
					Duration = 2,
				})
			end
			return
		end

		local aiReply = response.Body
		if not aiReply or #aiReply == 0 then
			if aiDebugMode then
				WindUI:Notify({ Title = "API错误", Content = "返回内容为空", Duration = 2 })
			end
			return
		end

		aiReply = aiReply:gsub("^%s+", ""):gsub("%s+$", "")

		if #aiReply > 100 then
			aiReply = string.sub(aiReply, 1, 100) .. "..."
		end

		sendChat(aiReply)

		if aiDebugMode then
			WindUI:Notify({
				Title = "AI回复",
				Content = string.format(
					"随机ID: %d | 回复: %s",
					randomCache,
					aiReply:sub(1, 20) .. (aiReply:len() > 20 and "..." or "")
				),
				Duration = 2,
			})
		end

		table.insert(aiMessageHistory, {
			player = playerName,
			question = question,
			reply = aiReply,
			time = os.time(),
			cacheId = randomCache,
		})

		if #aiMessageHistory > 50 then
			table.remove(aiMessageHistory, 1)
		end
	end

	local function setupAIChatListener()
		if aiChatConnection then
			aiChatConnection:Disconnect()
			aiChatConnection = nil
		end

		local textChannels = TextChatService:FindFirstChild("TextChannels")
		if not textChannels then
			if aiDebugMode then
				warn("[AI] 等待TextChannels...")
			end
			return
		end

		local general = textChannels:FindFirstChild("RBXGeneral")
		if not general then
			if aiDebugMode then
				warn("[AI] 等待RBXGeneral...")
			end
			return
		end

		aiChatConnection = general.MessageReceived:Connect(function(message)
			task.spawn(function()
				local textSource = message.TextSource
				if not textSource then
					return
				end

				local speaker = textSource.Name
				local content = message.Text

				if not content or #content == 0 then
					return
				end
				if speaker == Players.LocalPlayer.Name and not aiRespondToSelf then
					return
				end

				local lastReply = aiCooldownPlayers[speaker]
				if lastReply and os.time() - lastReply < 5 then
					return
				end

				aiCooldownPlayers[speaker] = os.time()
				task.wait(aiReplyDelay)
				sendAIResponse(speaker, content)
			end)
		end)

		if aiDebugMode then
			WindUI:Notify({ Title = "频道监听", Content = "已连接到聊天频道", Duration = 2 })
		end
	end

	local HistoryDisplay = AITab:Paragraph({
		Title = "最近回复",
		Desc = "暂无历史记录",
	})

	task.spawn(function()
		while true do
			task.wait(3)
			if aiEnabled and HistoryDisplay then
				local text = ""
				local count = 0
				for i = #aiMessageHistory, math.max(1, #aiMessageHistory - 4), -1 do
					local entry = aiMessageHistory[i]
					if entry then
						count = count + 1
						text = text .. string.format("[%s] %s\n", entry.player, string.sub(entry.reply, 1, 25))
						if #entry.reply > 25 then
							text = text .. "...\n"
						else
							text = text .. "\n"
						end
					end
					if count >= 5 then
						break
					end
				end

				if #text == 0 then
					text = "暂无历史记录"
				end

				pcall(function()
					HistoryDisplay:SetDesc(text)
				end)
			end
		end
	end)

	AITab:Button({
		Title = "测试AI功能",
		Desc = "发送一条测试消息给自己",
		Callback = function()
			local wasEnabled = aiEnabled
			aiEnabled = true
			sendAIResponse(Players.LocalPlayer.Name, "你好")
			task.wait(0.1)
			aiEnabled = wasEnabled
		end,
	})

	AITab:Button({
		Title = "查看统计",
		Desc = "显示历史记录数量",
		Callback = function()
			WindUI:Notify({
				Title = "AI会话信息",
				Content = string.format("历史记录: %d 条", #aiMessageHistory),
				Duration = 3,
			})
		end,
	})

	task.spawn(function()
		task.wait(1)
		setupAIChatListener()
	end)

	task.spawn(function()
		while true do
			task.wait(3)
			setupAIChatListener()
		end
	end)

	TextChatService.ChildAdded:Connect(function()
		task.wait(0.5)
		setupAIChatListener()
	end)

	Players.PlayerAdded:Connect(function()
		task.wait(1)
		setupAIChatListener()
	end)
end)

