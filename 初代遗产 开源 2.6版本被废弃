local function ApplyAnimationPack(packName, animations)
	local player = game:GetService("Players").LocalPlayer
	if not player.Character then
		WindUI:Notify({ Title = "错误", Content = "角色不存在", Duration = 2 })
		return
	end

	local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		WindUI:Notify({ Title = "错误", Content = "找不到Humanoid", Duration = 2 })
		return
	end

	if humanoid.RigType ~= Enum.HumanoidRigType.R15 then
		WindUI:Notify({ Title = "错误", Content = "只支持R15角色", Duration = 2 })
		return
	end

	local animate = player.Character:FindFirstChild("Animate")
	if not animate then
		WindUI:Notify({ Title = "错误", Content = "找不到Animate脚本", Duration = 2 })
		return
	end

	local successCount = 0
	local failCount = 0

	for animName, animId in pairs(animations) do
		pcall(function()
			local animConfig = animate:FindFirstChild(animName)
			if animConfig then
				local animObj = animConfig:FindFirstChildWhichIsA("Animation")
				if animObj then
					animObj.AnimationId = animId
					successCount = successCount + 1
				end
			end
		end)
	end

	WindUI:Notify({
		Title = "动画包",
		Content = string.format("%s 已应用（%d个动画）", packName, successCount),
		Duration = 3,
	})
end

