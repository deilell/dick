task.spawn(function()
	local TranslateTab = Window:Tab({
		Title = "翻译功能",
		Icon = "globe",
		Locked = false,
	})

	TranslateTab:Section({
		Title = "界面翻译",
		TextXAlignment = "Left",
		TextSize = 17,
	})

	TranslateTab:Paragraph({
		Title = "功能说明",
		Desc = [[翻译成功后结果会缓存，下次执行脚本时打开相同界面时会直接显示中文]],
	})

	local translationActive = false
	local translateThread = nil

	local function setupTranslation()
		if translationActive then
			return
		end
		translationActive = true

		local Http = game:GetService("HttpService")
		local Players = game:GetService("Players")
		local CoreGui = game:GetService("CoreGui")
		local Workspace = game:GetService("Workspace")

		local request = request or http_request or (syn and syn.request) or (fluxus and fluxus.request)
		if not (request and hookmetamethod) then
			WindUI:Notify({
				Title = "翻译功能",
				Content = "当前环境不支持翻译功能",
				Duration = 3,
			})
			translationActive = false
			return
		end

		local Encode = Http.UrlEncode
		local Decode = Http.JSONDecode
		local Spawn = task.spawn

		local Cache = {}
		local Queue = {}
		local RealText = setmetatable({}, { __mode = "k" })
		local Locks = {}
		local MonitoredContainers = {}

		local API = "https://clients5.google.com/translate_a/t?client=dict-chrome-ex&sl=auto&tl=zh-CN&q="

		local OldIdx
		OldIdx = hookmetamethod(game, "__index", function(t, k)
			if k == "Text" and not checkcaller() then
				return RealText[t]
			end
			return OldIdx(t, k)
		end)

		local function SetTrans(obj, origin, trans, vars)
			if obj.Text ~= origin then
				return
			end
			local k = 0
			local val = trans:gsub("%s?{[nN]}%s?", function()
				k = k + 1
				return vars[k] or ""
			end)
			if obj.Text ~= val then
				Locks[obj] = 1
				RealText[obj] = origin
				obj.Text = val
				Locks[obj] = nil
			end
		end

		local function Process(obj)
			if Locks[obj] then
				return
			end
			local txt = obj.Text
			if #txt < 2 then
				return
			end
			if txt:match("^[%d%s%p]+$") then
				return
			end

			local vars = {}
			local skel = txt:gsub("[%+$%-¥]?%d+[%d%.%,:]*[%d%%]*", function(m)
				vars[#vars + 1] = m
				return "{n}"
			end)

			if Cache[skel] then
				return SetTrans(obj, txt, Cache[skel], vars)
			end

			local q = Queue[skel]
			if q then
				q[#q + 1] = { obj, vars, txt }
				return
			end

			Queue[skel] = { { obj, vars, txt } }
			Spawn(function()
				local success, response = pcall(request, {
					Url = API .. Encode(Http, skel),
					Method = "GET",
				})
				local data = success and response.StatusCode == 200 and Decode(Http, response.Body)
				local result = type(data) == "table" and (type(data[1]) == "string" and data[1] or data[1][1])

				if result then
					Cache[skel] = result
					for _, item in next, Queue[skel] do
						if item[1].Parent then
							SetTrans(item[1], item[3], result, item[2])
						end
					end
				end
				Queue[skel] = nil
			end)
		end

		local function MonitorContainer(container)
			if MonitoredContainers[container] then
				return
			end
			MonitoredContainers[container] = true

			for _, v in next, container:GetDescendants() do
				if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then
					Process(v)
					v:GetPropertyChangedSignal("Text"):Connect(function()
						Process(v)
					end)
				end
			end

			container.DescendantAdded:Connect(function(child)
				if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("TextBox") then
					Process(child)
					child:GetPropertyChangedSignal("Text"):Connect(function()
						Process(child)
					end)
				end
			end)
		end

		local Roots = {
			Players.LocalPlayer:WaitForChild("PlayerGui"),
			(gethui and gethui()) or CoreGui,
			Workspace,
		}

		for _, root in next, Roots do
			MonitorContainer(root)
		end

		if CoreGui:FindFirstChildWhichIsA("ScreenGui") then
			for _, gui in next, CoreGui:GetChildren() do
				if gui:IsA("ScreenGui") then
					MonitorContainer(gui)
				end
			end
		end

		CoreGui.ChildAdded:Connect(function(child)
			if child:IsA("ScreenGui") then
				MonitorContainer(child)
			end
		end)

		Players.LocalPlayer:WaitForChild("PlayerGui").ChildAdded:Connect(function(child)
			if child:IsA("GuiBase2d") then
				MonitorContainer(child)
			end
		end)

		Workspace.DescendantAdded:Connect(function(child)
			if child:IsA("SurfaceGui") or child:IsA("BillboardGui") then
				MonitorContainer(child)
			end
		end)

		WindUI:Notify({
			Title = "翻译功能",
			Content = "翻译已激活，界面文本将自动转换为中文",
			Duration = 3,
		})
	end

	TranslateTab:Button({
		Title = "启动界面翻译",
		Desc = "点击后自动翻译游戏中的所有文本",
		Callback = function()
			if translationActive then
				WindUI:Notify({
					Title = "翻译功能",
					Content = "翻译已经处于激活状态",
					Duration = 2,
				})
				return
			end

			translateThread = task.spawn(function()
				setupTranslation()
			end)
		end,
	})

	TranslateTab:Button({
		Title = "重置翻译缓存",
		Desc = "清除已缓存的翻译结果",
		Callback = function()
			WindUI:Notify({
				Title = "翻译功能",
				Content = "请重新执行脚本来重置翻译",
				Duration = 3,
			})
		end,
	})

	TranslateTab:Button({
		Title = "停止翻译",
		Desc = "停止翻译功能（需要重新执行脚本）",
		Callback = function()
			translationActive = false
			if translateThread then
				task.cancel(translateThread)
				translateThread = nil
			end
			WindUI:Notify({
				Title = "翻译功能",
				Content = "翻译已停止，重新执行脚本可再次启用",
				Duration = 3,
			})
		end,
	})
end)

