	})

	local antennaEnabled = false
	local antennaInstance = nil
	local antennaLines = {}
	local antennaColor = Color3.new(0, 1, 0)
	local antennaUpdateConn = nil

	local function clearAllAntennas()
		for player, lineData in pairs(antennaLines) do
			if lineData then
				if lineData.useDrawing and lineData.line then
					pcall(function()
						lineData.line:Remove()
					end)
				elseif lineData.line then
					pcall(function()
						lineData.line:Destroy()
					end)
				end
			end
		end
		antennaLines = {}
	end

	local function createAntenna()
		if antennaUpdateConn then
			antennaUpdateConn:Disconnect()
			antennaUpdateConn = nil
		end
		clearAllAntennas()
		if antennaInstance then
			pcall(function()
				antennaInstance:Destroy()
			end)
			antennaInstance = nil
		end

		local screenGui = Instance.new("ScreenGui")
		screenGui.Name = "PlayerAntenna"
		screenGui.ResetOnSpawn = false
		screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
		screenGui.Parent = game:GetService("CoreGui")
		screenGui.Enabled = antennaEnabled

		local camera = workspace.CurrentCamera

		local useDrawing = pcall(function()
			return Drawing
		end)

		local function getTargetPosition()
			local viewportSize = camera.ViewportSize
			return Vector2.new(viewportSize.X / 2, 50)
		end

		local function createLine(player)
			if player == game:GetService("Players").LocalPlayer then
				return
			end

			if antennaLines[player] then
				if antennaLines[player].line then
					if useDrawing then
						pcall(function()
							antennaLines[player].line:Remove()
						end)
					else
						pcall(function()
							antennaLines[player].line:Destroy()
						end)
					end
				end
				antennaLines[player] = nil
			end

			local lineData = {}

			if useDrawing then
				local line = Drawing.new("Line")
				line.Thickness = 2
				line.Color = antennaColor
				line.Transparency = 0.3
				line.Visible = false
				line.Antialiasing = true
				lineData.line = line
				lineData.useDrawing = true
			else
				local lineFrame = Instance.new("Frame")
				lineFrame.Name = "Antenna_" .. player.Name
				lineFrame.BackgroundColor3 = antennaColor
				lineFrame.BackgroundTransparency = 0.3
				lineFrame.BorderSizePixel = 0
				lineFrame.Parent = screenGui
				lineData.line = lineFrame
				lineData.useDrawing = false
			end

			antennaLines[player] = lineData
			return lineData
		end

		local function updateAntenna(player)
			local localPlayer = game:GetService("Players").LocalPlayer
			if not localPlayer then
				return
			end

			if player == localPlayer then
				return
			end

			if not game:GetService("Players"):FindFirstChild(player.Name) then
				if antennaLines[player] then
					if antennaLines[player].useDrawing and antennaLines[player].line then
						pcall(function()
							antennaLines[player].line:Remove()
						end)
					elseif antennaLines[player].line then
						pcall(function()
							antennaLines[player].line:Destroy()
						end)
					end
					antennaLines[player] = nil
				end
				return
			end

			local character = player.Character
			if not character then
				if antennaLines[player] then
					if antennaLines[player].useDrawing then
						antennaLines[player].line.Visible = false
					else
						antennaLines[player].line.Visible = false
					end
				end
				return
			end

			local head = character:FindFirstChild("Head")
				or character:FindFirstChild("HumanoidRootPart")
				or character.PrimaryPart
			if not head then
				return
			end

			local headScreenPos, onScreen = camera:WorldToViewportPoint(head.Position)

			if not onScreen then
				if antennaLines[player] then
					if antennaLines[player].useDrawing then
						antennaLines[player].line.Visible = false
					else
						antennaLines[player].line.Visible = false
					end
				end
				return
			end

			local targetPos = getTargetPosition()

			if not antennaLines[player] then
				createLine(player)
			end

			local lineData = antennaLines[player]
			if not lineData then
				return
			end

			if lineData.useDrawing then
				local line = lineData.line
				if line then
					line.From = Vector2.new(headScreenPos.X, headScreenPos.Y)
					line.To = targetPos
					line.Visible = true
					line.Color = antennaColor
				end
			else
				local line = lineData.line
				if line then
					local startPos = Vector2.new(headScreenPos.X, headScreenPos.Y)
					local endPos = targetPos

					local delta = endPos - startPos
					local length = delta.Magnitude
					local angle = math.atan2(delta.Y, delta.X)

					line.Size = UDim2.new(0, length, 0, 2)
					line.Position = UDim2.new(0, startPos.X, 0, startPos.Y)
					line.Rotation = math.deg(angle)
					line.BackgroundColor3 = antennaColor
					line.Visible = true
				end
			end
		end

		local function updateAllAntennas()
			for _, lineData in pairs(antennaLines) do
				if lineData and lineData.line then
					if lineData.useDrawing then
						lineData.line.Visible = false
					else
						lineData.line.Visible = false
					end
				end
			end

			for _, player in ipairs(game:GetService("Players"):GetPlayers()) do
				updateAntenna(player)
			end
		end

		antennaUpdateConn = game:GetService("RunService").RenderStepped:Connect(updateAllAntennas)

		screenGui.Destroying:Connect(function()
			if antennaUpdateConn then
				antennaUpdateConn:Disconnect()
				antennaUpdateConn = nil
			end
			clearAllAntennas()
		end)

		antennaInstance = screenGui
	end

