local function setupAnimationSpeed(character)
	if not animationSpeedEnabled then
		return
	end
	if not character:IsDescendantOf(workspace) then
		return
	end

	local humanoid = character:WaitForChild("Humanoid")
	local animator = humanoid:WaitForChild("Animator")

	if animationSpeedConnection then
		animationSpeedConnection:Disconnect()
		animationSpeedConnection = nil
	end

	animationSpeedConnection = runService.Heartbeat:Connect(function()
		if not animationSpeedEnabled or not animator or not animator.Parent then
			return
		end

		local tracks = animator:GetPlayingAnimationTracks()

		for _, track in ipairs(tracks) do
			track:AdjustSpeed(animationSpeedValue)

			track.Looped = true
		end
	end)
end

