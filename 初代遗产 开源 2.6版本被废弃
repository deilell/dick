		playerPoints.Parent = mask

		local playerPointMap = {}

		local function worldToRadar(worldPosition, localPlayerPosition, localPlayerCFrame)
			local relative = worldPosition - localPlayerPosition
			local lookVector = localPlayerCFrame.LookVector
			local rightVector = localPlayerCFrame.RightVector
			local forward = relative:Dot(lookVector)
			local right = relative:Dot(rightVector)
			return Vector2.new(right, forward), relative.Y
		end

		local function updateRadar()
			local localPlayer = game:GetService("Players").LocalPlayer
			if not localPlayer then
				return
			end

			local character = localPlayer.Character
			if not character then
				return
			end

			local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso")
			if not rootPart then
				return
			end

			local localPosition = rootPart.Position
			local localCFrame = rootPart.CFrame

			for player, point in pairs(playerPointMap) do
				if point.dot then
					point.dot.Visible = false
				end
				if point.label then
					point.label.Visible = false
				end
			end

			for _, player in ipairs(game:GetService("Players"):GetPlayers()) do
				if player ~= localPlayer then
					local char = player.Character
					if char then
						local targetRoot = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
						if targetRoot then
							local targetPos = targetRoot.Position
							local relPos2D, heightDiff = worldToRadar(targetPos, localPosition, localCFrame)
							local horizontalDistance = math.sqrt(relPos2D.X ^ 2 + relPos2D.Y ^ 2)

							if horizontalDistance <= radarConfig.MaxDisplayDistance then
								if not playerPointMap[player] then
									local point = {}

									local dot = Instance.new("Frame")
									dot.Name = "Dot"
									dot.Size = UDim2.new(0, 8, 0, 8)
									dot.BackgroundColor3 = Color3.new(1, 0.3, 0.3)
									dot.BorderSizePixel = 0
									dot.ZIndex = 15
									local dotCorner = Instance.new("UICorner")
									dotCorner.CornerRadius = UDim.new(1, 0)
									dotCorner.Parent = dot
									dot.Parent = playerPoints

									local label = Instance.new("TextLabel")
									label.Name = "Label"
									label.Size = UDim2.new(0, 80, 0, 16)
									label.BackgroundTransparency = 1
									label.Text = player.Name
									label.TextColor3 = Color3.new(1, 1, 1)
									label.TextStrokeTransparency = 0.3
									label.Font = Enum.Font.SourceSans
									label.TextSize = 11
									label.ZIndex = 16
									label.Parent = playerPoints

									point.dot = dot
									point.label = label
									playerPointMap[player] = point
								end

								local point = playerPointMap[player]
								if point then
									local scale = radarConfig.Radius / radarConfig.MaxDisplayDistance
									local radarX = relPos2D.X * scale
									local radarY = -relPos2D.Y * scale

									local distanceFromCenter = math.sqrt(radarX ^ 2 + radarY ^ 2)
									if distanceFromCenter > radarConfig.Radius then
										local angle = math.atan2(radarY, radarX)
										radarX = math.cos(angle) * radarConfig.Radius
										radarY = math.sin(angle) * radarConfig.Radius
									end

									point.dot.Position = UDim2.new(0.5, radarX - 4, 0.5, radarY - 4)
									point.dot.Visible = true

									if heightDiff > 15 then
										point.dot.BackgroundColor3 = Color3.new(1, 0.8, 0)
									elseif heightDiff < -15 then
										point.dot.BackgroundColor3 = Color3.new(0.3, 0.6, 1)
									else
										point.dot.BackgroundColor3 = Color3.new(1, 0.3, 0.3)
									end

									if radarConfig.ShowNames then
										point.label.Visible = true
										point.label.Position = UDim2.new(0.5, radarX - 40, 0.5, radarY - 20)
									else
										point.label.Visible = false
									end
								end
							end
						end
					end
				end
			end

			for player, point in pairs(playerPointMap) do
				if not game:GetService("Players"):FindFirstChild(player.Name) then
					if point.dot then
						point.dot:Destroy()
					end
					if point.label then
						point.label:Destroy()
					end
					playerPointMap[player] = nil
				end
			end
		end

		radarUpdateConn = game:GetService("RunService").Heartbeat:Connect(updateRadar)

		screenGui.Destroying:Connect(function()
			if radarUpdateConn then
				radarUpdateConn:Disconnect()
				radarUpdateConn = nil
			end

			for player, point in pairs(playerPointMap) do
